# ══════════════════════════════════════════════════
# ENGERIS ONE — Variáveis de Ambiente
# ENGERIS — engeris.co.ao
# Copiar para .env e preencher com valores reais
# NUNCA commitar o ficheiro .env no git
# ══════════════════════════════════════════════════

# ── GERAL ──────────────────────────────────────────
NODE_ENV=development
APP_NAME="ENGERIS ONE"
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
API_VERSION=v1

# ── API ────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_SECRET=CHANGE_ME_LONG_RANDOM_STRING_MIN_64_CHARS

# ── JWT ────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ── BASE DE DADOS (PostgreSQL) ──────────────────────
DATABASE_URL=postgresql://engeris:CHANGE_ME_PASSWORD@localhost:5432/engeris_one_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=engeris_one_db
DATABASE_USER=engeris
DATABASE_PASSWORD=CHANGE_ME_PASSWORD
DATABASE_SSL=false

# ── REDIS ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── MINIO (Ficheiros) ───────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET_FATURAS=faturas
MINIO_BUCKET_DOCS=documentos
MINIO_BUCKET_MEDIA=media

# ── RESORTS ────────────────────────────────────────
RESORT_CABO_LEDO_ID=resort_cabo_ledo
RESORT_CABO_LEDO_NAME="Cabo Ledo Resort"
RESORT_CABO_LEDO_LAT=-9.0333
RESORT_CABO_LEDO_LNG=13.2667
RESORT_CABO_LEDO_GEOFENCE_RADIUS=300

RESORT_SANGANO_ID=resort_sangano
RESORT_SANGANO_NAME="Sangano Resort"
RESORT_SANGANO_LAT=-9.1000
RESORT_SANGANO_LNG=13.2000
RESORT_SANGANO_GEOFENCE_RADIUS=300

# ── AGT (Faturação Eletrónica Angola) ──────────────
AGT_ENVIRONMENT=sandbox
# AGT_ENVIRONMENT=production
AGT_API_URL=https://api.agt.minfin.gov.ao
AGT_NIF=CHANGE_ME_NIF_EMPRESA
AGT_PRIVATE_KEY_PATH=/run/secrets/agt_private_key
AGT_PUBLIC_KEY_PATH=/run/secrets/agt_public_key
AGT_CERTIFICATE_PATH=/run/secrets/agt_certificate

# ── SEAM API (Fechaduras TTLock) ───────────────────
SEAM_API_KEY=CHANGE_ME_SEAM_API_KEY
SEAM_WORKSPACE_ID=CHANGE_ME_SEAM_WORKSPACE_ID
SEAM_WEBHOOK_SECRET=CHANGE_ME_SEAM_WEBHOOK_SECRET

# ── SMS (Africa's Talking) ─────────────────────────
AT_USERNAME=CHANGE_ME_AT_USERNAME
AT_API_KEY=CHANGE_ME_AT_API_KEY
AT_SENDER_ID=ENGERIS
AT_ENVIRONMENT=sandbox
# AT_ENVIRONMENT=live

# ── EMAIL (Resend) ─────────────────────────────────
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
EMAIL_FROM=noreply@engeris.ao
EMAIL_FROM_NAME="ENGERIS ONE"

# ── 2FA (TOTP) ─────────────────────────────────────
TOTP_ISSUER="ENGERIS ONE"
TOTP_SECRET_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY

# ── MONITORIZAÇÃO ──────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMETHEUS_PORT=9090

# ── CORS ───────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://app.engeris.ao,https://staging.engeris.co.ao

# ── RATE LIMITING ──────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ── OFFLINE SYNC ───────────────────────────────────
SYNC_INTERVAL_MS=30000
SYNC_RETRY_ATTEMPTS=5
SYNC_RETRY_DELAY_MS=5000

# ── BACKUPS ────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_CRON="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=engeris-one-backups
