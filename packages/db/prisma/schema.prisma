// ENGERIS ONE — Prisma Schema
// Plataforma ERP Modular Multi-Indústria
// ENGERIS — engeris.co.ao

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════
// MULTI-TENANT & MÓDULOS
// ══════════════════════════════════════════════

// ── TENANT (Empresa/Cliente) ──────────────────
model Tenant {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  nif          String?    @unique     // NIF da empresa
  plan         TenantPlan @default(STARTER)
  logo         String?               // URL do logo
  primaryColor String?    @default("#0A5C8A")
  domain       String?    @unique    // domínio personalizado (White Label)
  maxUsers     Int        @default(5)
  maxBranches  Int        @default(1)
  trainingMode Boolean    @default(false)
  active       Boolean    @default(true)
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  modules  TenantModule[]
  branches Branch[]
  users    User[]

  @@index([slug])
  @@index([active])
}

enum TenantPlan { STARTER PROFESSIONAL ENTERPRISE CUSTOM }

// ── MÓDULOS DO TENANT ────────────────────────
model TenantModule {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleId  String   // 'core', 'pms', 'pos', 'finance', etc.
  active    Boolean  @default(true)
  activatedAt DateTime @default(now())
  expiresAt DateTime?

  @@unique([tenantId, moduleId])
  @@index([tenantId])
}

// ── FILIAL / UNIDADE ─────────────────────────
// Substitui "Resort" — agora genérico para qualquer tipo de negócio
model Branch {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  address        String?
  city           String?
  country        String?  @default("AO")
  lat            Float?
  lng            Float?
  geofenceRadius Int      @default(300)
  phone          String?
  email          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, active])
}

// ══════════════════════════════════════════════
// ENTIDADES DE NEGÓCIO
// ══════════════════════════════════════════════

// ── RESORTS (compatibilidade — alias para Branch hoteleiro) ──
model Resort {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  lat            Float
  lng            Float
  geofenceRadius Int      @default(300)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rooms         Room[]
  employees     Employee[]
  reservations  Reservation[]
  sales         Sale[]
  stockItems    StockItem[]
  tariffs       Tariff[]
  reviews       GuestReview[]
  serviceOrders RoomServiceOrder[]
  notifications Notification[]
}

// ── UTILIZADORES (Staff / Admin) ──────────────
model User {
  id           String   @id @default(cuid())
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  resortId     String?
  twoFaSecret  String?
  twoFaEnabled Boolean  @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  notifications Notification[]

  @@index([tenantId, active])
}

enum UserRole {
  SUPER_ADMIN
  RESORT_MANAGER
  RECEPTIONIST
  POS_OPERATOR
  STOCK_MANAGER
  HR_MANAGER
  STAFF
}

// ── REFRESH TOKENS ────────────────────────────
// FIX: permite revogar tokens sem esperar expiração (segurança)
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ── HÓSPEDES (App Hóspede) ────────────────────
// Separado de User — fluxo de autenticação diferente
model Guest {
  id          String   @id @default(cuid())
  name        String
  email       String?  @unique
  phone       String   @unique
  countryCode String?
  language    String   @default("pt")
  deviceToken String?  // Expo push token
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations  Reservation[]
  reviews       GuestReview[]
  serviceOrders RoomServiceOrder[]
  chatMessages  ChatMessage[]
  notifications Notification[]
}

// ── QUARTOS ──────────────────────────────────
model Room {
  id            String     @id @default(cuid())
  resortId      String
  resort        Resort     @relation(fields: [resortId], references: [id])
  number        String
  type          RoomType
  floor         Int
  capacity      Int
  pricePerNight Decimal    @db.Decimal(15, 2) // FIX: Float → Decimal
  seamDeviceId  String?
  status        RoomStatus @default(AVAILABLE)
  description   String?
  amenities     String[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  reservations Reservation[]

  @@unique([resortId, number])
  @@index([resortId, status])
  @@index([resortId, type])
}

enum RoomType   { STANDARD SUPERIOR SUITE VILLA }
enum RoomStatus { AVAILABLE OCCUPIED MAINTENANCE CLEANING }

// ── TARIFAS ───────────────────────────────────
// NOVO: gestão de preços sazonais e categorias tarifárias
model Tariff {
  id            String   @id @default(cuid())
  resortId      String
  resort        Resort   @relation(fields: [resortId], references: [id])
  name          String
  roomType      RoomType
  pricePerNight Decimal  @db.Decimal(15, 2)
  validFrom     DateTime
  validUntil    DateTime
  minNights     Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([resortId, roomType, validFrom])
}

// ── RESERVAS ─────────────────────────────────
model Reservation {
  id                 String                   @id @default(cuid())
  resortId           String
  resort             Resort                   @relation(fields: [resortId], references: [id])
  roomId             String
  room               Room                     @relation(fields: [roomId], references: [id])
  guestId            String?                  // ligação à conta app do hóspede (opcional)
  guest              Guest?                   @relation(fields: [guestId], references: [id])
  guestName          String
  guestEmail         String
  guestPhone         String
  checkIn            DateTime
  checkOut           DateTime
  nights             Int
  adults             Int
  children           Int                      @default(0)
  status             ReservationStatus        @default(CONFIRMED)
  bookingSource      BookingSource            @default(DIRECT)  // NOVO
  accessPinEncrypted String?                  // FIX: renomeado, agora encriptado AES-256
  pinValidFrom       DateTime?
  pinValidUntil      DateTime?
  totalAmount        Decimal                  @db.Decimal(15, 2) // FIX: Float → Decimal
  depositPaid        Decimal                  @db.Decimal(15, 2) @default(0) // NOVO
  paymentStatus      ReservationPaymentStatus @default(PENDING)  // NOVO
  notes              String?
  internalNotes      String?                  // NOVO: notas internas (não visíveis ao hóspede)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  sales         Sale[]
  review        GuestReview?
  serviceOrders RoomServiceOrder[]
  chatMessages  ChatMessage[]

  @@index([resortId, status])
  @@index([resortId, checkIn, checkOut])
  @@index([roomId, checkIn, checkOut])
  @@index([guestEmail])
}

enum ReservationStatus        { CONFIRMED CHECKED_IN CHECKED_OUT CANCELLED NO_SHOW }
enum ReservationPaymentStatus { PENDING PARTIAL PAID REFUNDED }
enum BookingSource            { DIRECT WEBSITE PHONE BOOKING_COM EXPEDIA AIRBNB OTHER }

// ── PRODUTOS ─────────────────────────────────
model Product {
  id         String     @id @default(cuid())
  name       String
  category   String
  department String
  unitPrice  Decimal    @db.Decimal(15, 2) // FIX: Float → Decimal
  taxRate    Decimal    @db.Decimal(5, 2)  @default(14) // FIX: Float → Decimal
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  saleItems  SaleItem[]

  @@index([department, active])
}

// ── VENDAS / POS ─────────────────────────────
model Sale {
  id             String        @id @default(cuid())
  resortId       String
  resort         Resort        @relation(fields: [resortId], references: [id])
  reservationId  String?
  reservation    Reservation?  @relation(fields: [reservationId], references: [id])
  operatorId     String?       // userId do caixa — NOVO
  totalAmount    Decimal       @db.Decimal(15, 2) // FIX: Float → Decimal
  taxAmount      Decimal       @db.Decimal(15, 2) @default(0) // FIX: Float → Decimal
  paymentMethod  PaymentMethod
  status         SaleStatus    @default(PENDING)
  invoiceNumber  String?       @unique
  invoiceSeries  String?
  agtStatus      String?
  agtQrCode      String?
  agtSubmittedAt DateTime?     // NOVO: quando foi enviado à AGT
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items SaleItem[]

  @@index([resortId, status])
  @@index([resortId, createdAt])
  @@index([invoiceNumber])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  unitPrice Decimal @db.Decimal(15, 2) // FIX: Float → Decimal
  taxRate   Decimal @db.Decimal(5, 2)  // FIX: Float → Decimal
  total     Decimal @db.Decimal(15, 2) // FIX: Float → Decimal

  @@index([saleId])
}

enum PaymentMethod { CASH CARD ROOM_CHARGE TRANSFER }
enum SaleStatus    { PENDING INVOICED CANCELLED }

// ── STOCK ─────────────────────────────────────
model StockItem {
  id         String          @id @default(cuid())
  resortId   String
  resort     Resort          @relation(fields: [resortId], references: [id])
  name       String
  department String
  unit       String
  currentQty Decimal         @db.Decimal(10, 3) // FIX: Float → Decimal
  minQty     Decimal         @db.Decimal(10, 3) // FIX: Float → Decimal
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  movements StockMovement[]

  @@index([resortId, department])
}

model StockMovement {
  id          String       @id @default(cuid())
  stockItemId String
  stockItem   StockItem    @relation(fields: [stockItemId], references: [id])
  type        MovementType
  qty         Decimal      @db.Decimal(10, 3) // FIX: Float → Decimal
  reason      String
  saleId      String?
  supplierId  String?      // NOVO: ligação ao fornecedor
  supplier    Supplier?    @relation(fields: [supplierId], references: [id])
  createdBy   String?      // userId
  createdAt   DateTime     @default(now())

  @@index([stockItemId, createdAt])
}

enum MovementType { IN OUT ADJUSTMENT }

// ── FORNECEDORES ──────────────────────────────
// NOVO: necessário para gestão de compras e rastreabilidade
model Supplier {
  id        String          @id @default(cuid())
  name      String
  nif       String?         @unique
  contact   String?
  phone     String?
  email     String?
  address   String?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  stockMovements StockMovement[]
}

// ── RH ────────────────────────────────────────
model Employee {
  id         String   @id @default(cuid())
  resortId   String
  resort     Resort   @relation(fields: [resortId], references: [id])
  name       String
  nif        String   @unique
  role       String
  department String
  baseSalary Decimal  @db.Decimal(15, 2) // FIX: Float → Decimal
  startDate  DateTime
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  attendance AttendanceRecord[]
  payrolls   Payroll[]
  shifts     Shift[]

  @@index([resortId, active])
  @@index([resortId, department])
}

model Shift {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  date       DateTime @db.Date  // data do turno (sem hora)
  startTime  DateTime           // FIX: String → DateTime
  endTime    DateTime           // FIX: String → DateTime
  department String
  createdAt  DateTime @default(now())

  @@index([employeeId, date])
}

// ── ASSIDUIDADE ───────────────────────────────
model AttendanceRecord {
  id         String         @id @default(cuid())
  employeeId String
  employee   Employee       @relation(fields: [employeeId], references: [id])
  type       AttendanceType
  lat        Float
  lng        Float
  validGps   Boolean
  syncedAt   DateTime?
  createdAt  DateTime       @default(now())

  @@index([employeeId, createdAt])
}

enum AttendanceType { ENTRY EXIT BREAK_START BREAK_END }

// ── SALÁRIOS ──────────────────────────────────
model Payroll {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id])
  month         Int
  year          Int
  baseSalary    Decimal   @db.Decimal(15, 2) // FIX: Float → Decimal
  hoursWorked   Decimal   @db.Decimal(8, 2)  // FIX: Float → Decimal
  overtimeHours Decimal   @db.Decimal(8, 2)  // FIX: Float → Decimal
  overtimePay   Decimal   @db.Decimal(15, 2) // FIX: Float → Decimal
  absenceDays   Int
  absenceDeduct Decimal   @db.Decimal(15, 2) // FIX: Float → Decimal
  netSalary     Decimal   @db.Decimal(15, 2) // FIX: Float → Decimal
  processed     Boolean   @default(false)
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@unique([employeeId, month, year])
  @@index([month, year])
}

// ── MANUTENÇÃO / LIMPEZA ──────────────────────
model MaintenanceTicket {
  id          String         @id @default(cuid())
  resortId    String
  roomId      String?
  location    String
  description String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  assignedTo  String?        // employeeId — NOVO
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([resortId, status])
  @@index([roomId, status])
}

enum TicketPriority { LOW MEDIUM HIGH URGENT }
enum TicketStatus   { OPEN IN_PROGRESS RESOLVED CLOSED }

// ── AVALIAÇÕES ────────────────────────────────
// NOVO: pedido no Sprint 3, agora no schema
model GuestReview {
  id            String      @id @default(cuid())
  resortId      String
  resort        Resort      @relation(fields: [resortId], references: [id])
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  guestId       String?
  guest         Guest?      @relation(fields: [guestId], references: [id])
  guestName     String
  overallRating Int         // 1-5
  cleanliness   Int?        // 1-5
  service       Int?        // 1-5
  location      Int?        // 1-5
  valueForMoney Int?        // 1-5
  comment       String?
  language      String      @default("pt")
  published     Boolean     @default(false)
  reply         String?     // resposta da gestão
  repliedAt     DateTime?
  createdAt     DateTime    @default(now())

  @@index([resortId, published])
  @@index([resortId, overallRating])
}

// ── ROOM SERVICE / PEDIDOS ────────────────────
// NOVO: pedido no Sprint 3, agora no schema
model RoomServiceOrder {
  id            String             @id @default(cuid())
  resortId      String
  resort        Resort             @relation(fields: [resortId], references: [id])
  reservationId String
  reservation   Reservation        @relation(fields: [reservationId], references: [id])
  guestId       String?
  guest         Guest?             @relation(fields: [guestId], references: [id])
  type          ServiceOrderType
  items         Json               // [{ name, qty, price, notes }]
  notes         String?
  status        ServiceOrderStatus @default(PENDING)
  scheduledAt   DateTime?
  completedAt   DateTime?
  assignedTo    String?            // employeeId
  totalAmount   Decimal?           @db.Decimal(15, 2)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([resortId, status])
  @@index([reservationId])
}

enum ServiceOrderType   { ROOM_SERVICE HOUSEKEEPING SPA RESTAURANT ACTIVITY TRANSPORT OTHER }
enum ServiceOrderStatus { PENDING CONFIRMED IN_PROGRESS COMPLETED CANCELLED }

// ── CHAT ──────────────────────────────────────
// NOVO: WebSocket chat hóspede ↔ receção (Sprint 3)
model ChatMessage {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  guestId       String?
  guest         Guest?      @relation(fields: [guestId], references: [id])
  senderType    SenderType
  senderId      String      // guestId ou userId
  content       String
  readAt        DateTime?
  createdAt     DateTime    @default(now())

  @@index([reservationId, createdAt])
}

enum SenderType { GUEST STAFF }

// ── NOTIFICAÇÕES ─────────────────────────────
// NOVO: rastreio de push/SMS/email enviados
model Notification {
  id        String              @id @default(cuid())
  userId    String?
  user      User?               @relation(fields: [userId], references: [id])
  guestId   String?
  guest     Guest?              @relation(fields: [guestId], references: [id])
  resortId  String?
  resort    Resort?             @relation(fields: [resortId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, status])
  @@index([guestId, status])
  @@index([createdAt])
}

enum NotificationType    { RESERVATION_CONFIRMED RESERVATION_REMINDER CHECKIN_READY PIN_GENERATED CHECKOUT_REMINDER INVOICE_READY STOCK_ALERT ATTENDANCE_MISSING PAYROLL_PROCESSED MAINTENANCE_ASSIGNED }
enum NotificationChannel { PUSH SMS EMAIL IN_APP }
enum NotificationStatus  { PENDING SENT DELIVERED READ FAILED }

// ── AUDITORIA ─────────────────────────────────
// NOVO: obrigatório para conformidade fiscal AGT
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  action    String   // CREATE UPDATE DELETE LOGIN LOGOUT INVOICE_EMIT etc.
  entity    String   // "Reservation" "Sale" "User" "Payroll" etc.
  entityId  String?
  before    Json?    // estado anterior
  after     Json?    // estado novo
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ── DOCUMENTOS ───────────────────────────────
// NOVO: BI hóspede, contratos colaboradores, etc.
model Document {
  id          String       @id @default(cuid())
  entityType  String       // "Guest" "Employee" "Reservation"
  entityId    String
  type        DocumentType
  name        String
  fileUrl     String
  mimeType    String
  sizeBytes   Int
  uploadedBy  String       // userId
  createdAt   DateTime     @default(now())

  @@index([entityType, entityId])
}

enum DocumentType { ID_CARD PASSPORT CONTRACT INVOICE MEDICAL VISA OTHER }

// ══════════════════════════════════════════════
// FATURAÇÃO UNIVERSAL & MODO FORMAÇÃO
// ══════════════════════════════════════════════

// ── SÉRIES DE FATURAÇÃO ─────────────────────
// Cada tenant tem as suas séries; modo formação usa série separada
model InvoiceSeries {
  id           String      @id @default(cuid())
  tenantId     String
  resortId     String?             // filial (opcional)
  documentType InvoiceDocType
  series       String              // "A", "B", "TREINO"
  prefix       String              // "FT", "FR", "NC", etc.
  lastNumber   Int         @default(0)
  isTraining   Boolean     @default(false)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  invoices     Invoice[]

  @@unique([tenantId, documentType, series])
  @@index([tenantId])
}

// ── FATURAS / DOCUMENTOS FISCAIS ─────────────
// Genérico para qualquer indústria
model Invoice {
  id              String         @id @default(cuid())
  tenantId        String
  resortId        String?
  seriesId        String
  series          InvoiceSeries  @relation(fields: [seriesId], references: [id])
  documentType    InvoiceDocType
  number          Int                     // número sequencial
  fullNumber      String         @unique  // "FT A/00001" ou "FT-TREINO T/00001"
  isTraining      Boolean        @default(false) // modo formação
  // Cliente
  clientName      String
  clientNif       String?
  clientAddress   String?
  clientEmail     String?
  clientPhone     String?
  // Valores
  subtotal        Decimal        @db.Decimal(15, 2)
  taxAmount       Decimal        @db.Decimal(15, 2)
  totalAmount     Decimal        @db.Decimal(15, 2)
  currency        String         @default("AOA")
  exchangeRate    Decimal?       @db.Decimal(10, 4) // câmbio para multi-moeda
  // Pagamento
  paymentMethod   PaymentMethod?
  paidAt          DateTime?
  dueDate         DateTime?
  // AGT
  agtHash         String?                 // hash RSA do documento
  agtPreviousHash String?                 // hash do documento anterior (cadeia)
  agtStatus       String?                 // pending, submitted, accepted, rejected
  agtQrCode       String?
  agtSubmittedAt  DateTime?
  // Referências
  relatedInvoiceId String?                // para NC referenciando FT
  saleId          String?                 // ligação a Sale (POS)
  reservationId   String?                 // ligação a Reservation (PMS)
  notes           String?
  pdfUrl          String?
  // Meta
  createdBy       String?                 // userId
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items InvoiceItem[]

  @@index([tenantId, documentType])
  @@index([tenantId, isTraining])
  @@index([tenantId, createdAt])
  @@index([clientNif])
  @@index([fullNumber])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2)  @default(14)
  discount    Decimal @db.Decimal(5, 2)  @default(0)
  total       Decimal @db.Decimal(15, 2)
  productId   String?
  unit        String? // "un", "kg", "m", "h", "m²", etc.

  @@index([invoiceId])
}

enum InvoiceDocType {
  FT    // Fatura
  FR    // Fatura-Recibo
  NC    // Nota de Crédito
  ND    // Nota de Débito
  ORC   // Orçamento
  PF    // Proforma
  RC    // Recibo
  GT    // Guia de Transporte
  AM    // Auto de Medição
  CS    // Contrato de Serviço
}

// ══════════════════════════════════════════════
// MÓDULO: SEGURANÇA ELETRÓNICA (SEC)
// ══════════════════════════════════════════════

// ── CONTRATOS DE SEGURANÇA ──────────────────
model SecurityContract {
  id            String              @id @default(cuid())
  tenantId      String
  branchId      String?
  clientName    String
  clientNif     String?
  clientAddress String?
  clientPhone   String?
  clientEmail   String?
  contractType  SecurityContractType
  startDate     DateTime
  endDate       DateTime?
  renewAuto     Boolean             @default(true)
  monthlyValue  Decimal             @db.Decimal(15, 2)
  currency      String              @default("AOA")
  status        ContractStatus      @default(ACTIVE)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  installations SecurityInstallation[]

  @@index([tenantId, status])
  @@index([tenantId, endDate])
}

enum SecurityContractType { MONITORING PATROL CCTV ALARM ACCESS_CONTROL MIXED }
enum ContractStatus { DRAFT ACTIVE SUSPENDED EXPIRED CANCELLED }

// ── INSTALAÇÕES DE EQUIPAMENTOS ─────────────
model SecurityInstallation {
  id           String              @id @default(cuid())
  tenantId     String
  contractId   String?
  contract     SecurityContract?   @relation(fields: [contractId], references: [id])
  clientName   String
  address      String
  lat          Float?
  lng          Float?
  installationType SecurityInstallationType
  equipmentList Json               // [{ name, brand, model, serial, qty }]
  status       InstallationStatus  @default(PLANNED)
  scheduledDate DateTime?
  completedDate DateTime?
  assignedTo   String?             // employeeId / técnico
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([tenantId, status])
  @@index([contractId])
}

enum SecurityInstallationType { CCTV ALARM INTERCOM ACCESS_CONTROL FIRE_DETECTION ELECTRIC_FENCE MIXED }
enum InstallationStatus { PLANNED IN_PROGRESS COMPLETED CANCELLED }

// ── INCIDENTES / OCORRÊNCIAS ────────────────
model SecurityIncident {
  id           String            @id @default(cuid())
  tenantId     String
  branchId     String?
  contractId   String?
  type         IncidentType
  severity     IncidentSeverity  @default(MEDIUM)
  title        String
  description  String
  location     String?
  lat          Float?
  lng          Float?
  reportedBy   String?
  assignedTo   String?
  status       IncidentStatus    @default(OPEN)
  resolvedAt   DateTime?
  resolution   String?
  photos       String[]          // URLs de fotos
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, severity])
  @@index([tenantId, createdAt])
}

enum IncidentType { INTRUSION THEFT VANDALISM FIRE EQUIPMENT_FAILURE ALARM_TRIGGER ACCESS_VIOLATION OTHER }
enum IncidentSeverity { LOW MEDIUM HIGH CRITICAL }
enum IncidentStatus { OPEN INVESTIGATING IN_PROGRESS RESOLVED CLOSED }

// ── RONDAS DE SEGURANÇA ──────────────────────
model SecurityPatrol {
  id           String        @id @default(cuid())
  tenantId     String
  branchId     String?
  guardId      String                // employeeId
  guardName    String
  route        String?               // nome da rota
  startedAt    DateTime
  endedAt      DateTime?
  status       PatrolStatus  @default(IN_PROGRESS)
  checkpoints  Json          @default("[]") // [{ name, lat, lng, checkedAt, notes, photo }]
  notes        String?
  createdAt    DateTime      @default(now())

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

enum PatrolStatus { SCHEDULED IN_PROGRESS COMPLETED INTERRUPTED }

// ══════════════════════════════════════════════
// MÓDULO: ENGENHARIA & CONSTRUÇÃO (ENG)
// ══════════════════════════════════════════════

// ── PROJETOS ────────────────────────────────
model EngineeringProject {
  id            String          @id @default(cuid())
  tenantId      String
  branchId      String?
  name          String
  code          String?                  // código interno do projeto
  clientName    String
  clientNif     String?
  clientPhone   String?
  clientEmail   String?
  projectType   ProjectType
  description   String?
  address       String?
  lat           Float?
  lng           Float?
  budget        Decimal?        @db.Decimal(15, 2)
  currency      String          @default("AOA")
  startDate     DateTime?
  estimatedEnd  DateTime?
  actualEnd     DateTime?
  status        ProjectStatus   @default(PLANNING)
  managerId     String?                  // employeeId — gestor de projeto
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  works         ConstructionWork[]
  budgetItems   BudgetItem[]
  measurements  WorkMeasurement[]

  @@index([tenantId, status])
  @@index([tenantId, projectType])
}

enum ProjectType { CONSTRUCTION RENOVATION MAINTENANCE DESIGN CONSULTATION INSPECTION OTHER }
enum ProjectStatus { PLANNING APPROVED IN_PROGRESS ON_HOLD COMPLETED CANCELLED }

// ── OBRAS ───────────────────────────────────
model ConstructionWork {
  id           String         @id @default(cuid())
  tenantId     String
  projectId    String
  project      EngineeringProject @relation(fields: [projectId], references: [id])
  name         String
  description  String?
  phase        String?                 // "Fundação", "Estrutura", "Acabamentos"
  startDate    DateTime?
  endDate      DateTime?
  progress     Int            @default(0) // 0-100%
  status       WorkStatus     @default(PENDING)
  assignedTeam String?                 // nome da equipa
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId, projectId])
  @@index([status])
}

enum WorkStatus { PENDING IN_PROGRESS COMPLETED BLOCKED CANCELLED }

// ── ORÇAMENTOS TÉCNICOS (BQ) ────────────────
model BudgetItem {
  id           String  @id @default(cuid())
  tenantId     String
  projectId    String
  project      EngineeringProject @relation(fields: [projectId], references: [id])
  code         String?                // código do item (ex: "1.2.3")
  description  String
  unit         String                 // "m²", "m³", "un", "kg", "ml", etc.
  quantity     Decimal @db.Decimal(10, 3)
  unitPrice    Decimal @db.Decimal(15, 2)
  total        Decimal @db.Decimal(15, 2)
  category     String?                // "Material", "Mão de Obra", "Equipamento"
  notes        String?
  createdAt    DateTime @default(now())

  @@index([tenantId, projectId])
}

// ── AUTOS DE MEDIÇÃO ────────────────────────
model WorkMeasurement {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String
  project      EngineeringProject @relation(fields: [projectId], references: [id])
  number       Int                     // número sequencial do auto
  period       String                  // "Março 2026"
  measuredBy   String?                 // técnico responsável
  approvedBy   String?
  approvedAt   DateTime?
  items        Json                    // [{ budgetItemId, description, unit, qty, unitPrice, total }]
  subtotal     Decimal  @db.Decimal(15, 2)
  taxAmount    Decimal  @db.Decimal(15, 2)
  totalAmount  Decimal  @db.Decimal(15, 2)
  status       MeasurementStatus @default(DRAFT)
  invoiceId    String?                 // ligação à fatura gerada
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, projectId])
  @@index([status])
}

enum MeasurementStatus { DRAFT SUBMITTED APPROVED INVOICED REJECTED }

// ══════════════════════════════════════════════
// MÓDULO: ELETRICIDADE & ENERGIA (ELEC)
// ══════════════════════════════════════════════

// ── PROJETOS ELÉTRICOS ──────────────────────
model ElectricalProject {
  id            String          @id @default(cuid())
  tenantId      String
  branchId      String?
  name          String
  clientName    String
  clientNif     String?
  clientPhone   String?
  projectType   ElecProjectType
  voltageLevel  VoltageLevel    @default(LOW)
  address       String?
  description   String?
  budget        Decimal?        @db.Decimal(15, 2)
  currency      String          @default("AOA")
  startDate     DateTime?
  estimatedEnd  DateTime?
  status        ProjectStatus   @default(PLANNING)
  assignedTo    String?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  inspections   ElectricalInspection[]
  certifications ElectricalCertification[]

  @@index([tenantId, status])
  @@index([tenantId, projectType])
}

enum ElecProjectType { NEW_INSTALLATION RENOVATION EXPANSION MAINTENANCE EMERGENCY }
enum VoltageLevel { LOW MEDIUM HIGH }

// ── INSPEÇÕES ELÉTRICAS ─────────────────────
model ElectricalInspection {
  id           String            @id @default(cuid())
  tenantId     String
  projectId    String?
  project      ElectricalProject? @relation(fields: [projectId], references: [id])
  address      String
  clientName   String
  inspectorId  String?                  // employeeId
  inspectorName String?
  inspectionType InspectionType
  scheduledDate DateTime?
  completedDate DateTime?
  result       InspectionResult?
  checklist    Json              @default("[]") // [{ item, passed, notes }]
  findings     String?
  photos       String[]
  status       InspectionStatus  @default(SCHEDULED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, scheduledDate])
}

enum InspectionType { INITIAL PERIODIC EXTRAORDINARY POST_INCIDENT }
enum InspectionResult { APPROVED APPROVED_WITH_CONDITIONS REJECTED }
enum InspectionStatus { SCHEDULED IN_PROGRESS COMPLETED CANCELLED }

// ── CERTIFICAÇÕES ELÉTRICAS ─────────────────
model ElectricalCertification {
  id             String            @id @default(cuid())
  tenantId       String
  projectId      String?
  project        ElectricalProject? @relation(fields: [projectId], references: [id])
  clientName     String
  address        String
  certNumber     String?           @unique
  certType       CertificationType
  issuedAt       DateTime?
  expiresAt      DateTime?
  issuedBy       String?                 // técnico responsável
  status         CertificationStatus @default(PENDING)
  pdfUrl         String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
}

enum CertificationType { INSTALLATION_CERT INSPECTION_CERT COMPLIANCE_CERT ENERGY_CERT }
enum CertificationStatus { PENDING ISSUED EXPIRED REVOKED }

// ══════════════════════════════════════════════
// MÓDULO: CRM & CLIENTES
// ══════════════════════════════════════════════

model Client {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  nif         String?
  phone       String?
  email       String?
  address     String?
  city        String?
  country     String?  @default("AO")
  type        ClientType @default(INDIVIDUAL)
  source      String?             // como conheceu
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals       Deal[]

  @@index([tenantId, active])
  @@index([tenantId, name])
}

enum ClientType { INDIVIDUAL COMPANY GOVERNMENT }

// ── PIPELINE DE VENDAS ──────────────────────
model Deal {
  id          String     @id @default(cuid())
  tenantId    String
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id])
  title       String
  value       Decimal?   @db.Decimal(15, 2)
  currency    String     @default("AOA")
  stage       DealStage  @default(LEAD)
  probability Int        @default(0)    // 0-100%
  assignedTo  String?                   // userId
  expectedClose DateTime?
  closedAt    DateTime?
  lostReason  String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId, stage])
  @@index([tenantId, clientId])
}

enum DealStage { LEAD QUALIFIED PROPOSAL NEGOTIATION WON LOST }

// ══════════════════════════════════════════════
// MÓDULO: FROTAS & LOGÍSTICA
// ══════════════════════════════════════════════

model Vehicle {
  id           String        @id @default(cuid())
  tenantId     String
  branchId     String?
  plate        String
  brand        String
  model        String
  year         Int?
  type         VehicleType
  fuelType     FuelType      @default(DIESEL)
  mileage      Int           @default(0)
  status       VehicleStatus @default(AVAILABLE)
  assignedTo   String?                  // driverId
  insuranceExp DateTime?
  inspectionExp DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  fuelLogs     FuelLog[]

  @@unique([tenantId, plate])
  @@index([tenantId, status])
}

enum VehicleType { CAR VAN TRUCK MOTORCYCLE BUS EQUIPMENT }
enum FuelType { DIESEL GASOLINE ELECTRIC HYBRID }
enum VehicleStatus { AVAILABLE IN_USE MAINTENANCE DECOMMISSIONED }

model FuelLog {
  id         String   @id @default(cuid())
  tenantId   String
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId   String?
  driverName String?
  date       DateTime
  liters     Decimal  @db.Decimal(8, 2)
  pricePerLiter Decimal @db.Decimal(10, 2)
  totalCost  Decimal  @db.Decimal(15, 2)
  mileage    Int
  station    String?
  createdAt  DateTime @default(now())

  @@index([tenantId, vehicleId])
  @@index([tenantId, date])
}

// ══════════════════════════════════════════════
// MÓDULO: CONTRATOS & JURÍDICO
// ══════════════════════════════════════════════

model ServiceContract {
  id            String          @id @default(cuid())
  tenantId      String
  clientName    String
  clientNif     String?
  title         String
  description   String?
  contractType  String                // "Manutenção", "Segurança", "Limpeza", etc.
  startDate     DateTime
  endDate       DateTime?
  renewAuto     Boolean         @default(false)
  renewDaysBefore Int           @default(30)
  monthlyValue  Decimal?        @db.Decimal(15, 2)
  totalValue    Decimal?        @db.Decimal(15, 2)
  currency      String          @default("AOA")
  status        ContractStatus  @default(ACTIVE)
  pdfUrl        String?
  alertSent     Boolean         @default(false)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, endDate])
}

// ══════════════════════════════════════════════
// MÓDULO: SPA & BEM-ESTAR
// ══════════════════════════════════════════════

model SpaService {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String               // MASSAGE, FACIAL, BODY, HAIR, NAILS, OTHER
  duration    Int                   // minutos
  price       Decimal  @db.Decimal(15, 2)
  description String?
  active      Boolean  @default(true)
  bookings    SpaBooking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, active])
}

model SpaBooking {
  id          String   @id @default(cuid())
  tenantId    String
  serviceId   String
  service     SpaService @relation(fields: [serviceId], references: [id])
  clientName  String
  clientPhone String?
  therapist   String?
  date        DateTime
  status      String   @default("SCHEDULED")  // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  notes       String?
  totalPrice  Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, status])
}

// ══════════════════════════════════════════════
// MÓDULO: EVENTOS & ATIVIDADES
// ══════════════════════════════════════════════

model Event {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  description   String?
  eventType     String               // CONFERENCE, WEDDING, PARTY, WORKSHOP, MEETING, SPORTS, CULTURAL, OTHER
  location      String?
  startDate     DateTime
  endDate       DateTime?
  maxCapacity   Int?
  currentGuests Int      @default(0)
  price         Decimal? @db.Decimal(15, 2)
  status        String   @default("PLANNED")  // PLANNED, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  organizer     String?
  contactPhone  String?
  contactEmail  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, startDate])
  @@index([tenantId, status])
}

// ══════════════════════════════════════════════
// MÓDULO: IMOBILIÁRIO
// ══════════════════════════════════════════════

model Property {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  propertyType  String               // APARTMENT, HOUSE, LAND, COMMERCIAL, WAREHOUSE, OFFICE
  purpose       String   @default("SALE")  // SALE, RENT, BOTH
  address       String?
  city          String?
  area          Decimal? @db.Decimal(10, 2)  // m²
  bedrooms      Int?
  bathrooms     Int?
  price         Decimal? @db.Decimal(15, 2)
  rentPrice     Decimal? @db.Decimal(15, 2)
  status        String   @default("AVAILABLE")  // AVAILABLE, RESERVED, SOLD, RENTED, UNAVAILABLE
  description   String?
  features      String[]             // piscina, garagem, varanda, etc.
  photos        String[]
  ownerName     String?
  ownerPhone    String?
  lat           Float?
  lng           Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, propertyType])
}

// ══════════════════════════════════════════════
// MÓDULO: LOGÍSTICA & TRANSPORTE
// ══════════════════════════════════════════════

model Shipment {
  id              String   @id @default(cuid())
  tenantId        String
  trackingCode    String?
  origin          String
  destination     String
  clientName      String?
  clientPhone     String?
  weight          Decimal? @db.Decimal(10, 2)  // kg
  volume          Decimal? @db.Decimal(10, 3)  // m³
  shipmentType    String               // PACKAGE, PALLET, CONTAINER, DOCUMENT, BULK
  status          String   @default("PENDING")  // PENDING, PICKED_UP, IN_TRANSIT, DELIVERED, RETURNED, CANCELLED
  estimatedDelivery DateTime?
  deliveredAt     DateTime?
  cost            Decimal? @db.Decimal(15, 2)
  driverId        String?
  vehicleId       String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, trackingCode])
}

// ══════════════════════════════════════════════
// MÓDULO: EDUCAÇÃO & FORMAÇÃO
// ══════════════════════════════════════════════

model Course {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  category    String?              // TECHNICAL, SAFETY, MANAGEMENT, LANGUAGE, CERTIFICATION, OTHER
  instructor  String?
  duration    Int?                 // horas
  maxStudents Int?
  price       Decimal? @db.Decimal(15, 2)
  status      String   @default("ACTIVE")  // ACTIVE, INACTIVE, ARCHIVED
  description String?
  enrollments Enrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model Enrollment {
  id          String   @id @default(cuid())
  tenantId    String
  courseId     String
  course      Course   @relation(fields: [courseId], references: [id])
  studentName String
  studentEmail String?
  studentPhone String?
  enrolledAt  DateTime @default(now())
  completedAt DateTime?
  grade       Decimal? @db.Decimal(5, 2)
  status      String   @default("ENROLLED")  // ENROLLED, IN_PROGRESS, COMPLETED, DROPPED, FAILED
  certificateUrl String?
  notes       String?

  @@index([tenantId, courseId])
  @@index([tenantId, status])
}

// ══════════════════════════════════════════════
// MÓDULO: SAÚDE & CLÍNICA
// ══════════════════════════════════════════════

model Patient {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  nif         String?
  birthDate   DateTime?
  gender      String?              // M, F, OTHER
  phone       String?
  email       String?
  address     String?
  bloodType   String?
  allergies   String?
  notes       String?
  appointments Appointment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, name])
}

model Appointment {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorName  String?
  specialty   String?              // GENERAL, CARDIOLOGY, DERMATOLOGY, DENTAL, PHYSIOTHERAPY, OTHER
  date        DateTime
  duration    Int      @default(30)  // minutos
  status      String   @default("SCHEDULED")  // SCHEDULED, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  diagnosis   String?
  prescription String?
  notes       String?
  cost        Decimal? @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, patientId])
}

// ══════════════════════════════════════════════
// MÓDULO: AGRICULTURA
// ══════════════════════════════════════════════

model Farm {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  location    String?
  totalArea   Decimal? @db.Decimal(10, 2)  // hectares
  crops       Crop[]
  harvests    Harvest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Crop {
  id          String   @id @default(cuid())
  tenantId    String
  farmId      String
  farm        Farm     @relation(fields: [farmId], references: [id])
  name        String               // Milho, Café, Banana, Mandioca, etc.
  variety     String?
  area        Decimal? @db.Decimal(10, 2)  // hectares
  plantedDate DateTime?
  expectedHarvest DateTime?
  status      String   @default("PLANTED")  // PLANTED, GROWING, READY, HARVESTED, FAILED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, farmId])
}

model Harvest {
  id          String   @id @default(cuid())
  tenantId    String
  farmId      String
  farm        Farm     @relation(fields: [farmId], references: [id])
  cropName    String
  quantity    Decimal  @db.Decimal(10, 2)  // kg ou toneladas
  unit        String   @default("kg")
  quality     String?              // A, B, C
  harvestDate DateTime
  revenue     Decimal? @db.Decimal(15, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, farmId])
  @@index([tenantId, harvestDate])
}

// ══════════════════════════════════════════════
// MÓDULO: ATIVIDADES & EXPERIÊNCIAS
// ══════════════════════════════════════════════

model Activity {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  category      String               // ADVENTURE, WATER, NATURE, CULTURAL, SPORTS, WELLNESS, GASTRONOMY, OTHER
  description   String?
  location      String?
  duration      Int?                 // minutos
  maxParticipants Int?
  minAge        Int?
  price         Decimal? @db.Decimal(15, 2)
  equipmentIncluded String[]
  difficulty    String   @default("EASY")  // EASY, MODERATE, HARD, EXTREME
  status        String   @default("ACTIVE")  // ACTIVE, INACTIVE, SEASONAL, CANCELLED
  seasonStart   DateTime?
  seasonEnd     DateTime?
  photos        String[]
  bookings      ActivityBooking[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, category])
}

model ActivityBooking {
  id            String   @id @default(cuid())
  tenantId      String
  activityId    String
  activity      Activity @relation(fields: [activityId], references: [id])
  clientName    String
  clientPhone   String?
  clientEmail   String?
  participants  Int      @default(1)
  date          DateTime
  status        String   @default("BOOKED")  // BOOKED, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  totalPrice    Decimal  @db.Decimal(15, 2)
  guide         String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, activityId])
}

// ══════════════════════════════════════════════
// MÓDULO: RETALHO
// ══════════════════════════════════════════════

model RetailStore {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  address     String?
  city        String?
  phone       String?
  manager     String?
  status      String   @default("ACTIVE")  // ACTIVE, INACTIVE, RENOVATION
  openTime    String?                      // "08:00"
  closeTime   String?                      // "22:00"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model RetailSale {
  id          String   @id @default(cuid())
  tenantId    String
  storeId     String?
  saleNumber  String?
  clientName  String?
  clientNif   String?
  items       Json                        // [{name, qty, price, total}]
  subtotal    Decimal  @db.Decimal(15, 2)
  taxAmount   Decimal  @db.Decimal(15, 2)
  discount    Decimal  @db.Decimal(15, 2) @default(0)
  totalAmount Decimal  @db.Decimal(15, 2)
  paymentMethod String @default("CASH")   // CASH, CARD, TRANSFER, MULTICAIXA
  status      String   @default("COMPLETED")  // COMPLETED, REFUNDED, CANCELLED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, storeId])
}

// ══════════════════════════════════════════════
// MÓDULO: MANUFATURA
// ══════════════════════════════════════════════

model ProductionOrder {
  id            String   @id @default(cuid())
  tenantId      String
  orderNumber   String?
  productName   String
  quantity      Decimal  @db.Decimal(10, 2)
  unit          String   @default("un")
  priority      String   @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  status        String   @default("PLANNED")  // PLANNED, IN_PRODUCTION, QUALITY_CHECK, COMPLETED, CANCELLED
  startDate     DateTime?
  expectedEnd   DateTime?
  completedAt   DateTime?
  cost          Decimal? @db.Decimal(15, 2)
  supervisor    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
}

// ══════════════════════════════════════════════
// MÓDULO: CONSULTORIA & SERVIÇOS PROFISSIONAIS
// ══════════════════════════════════════════════

model ConsultingProject {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  clientName    String
  projectType   String               // STRATEGY, TECHNOLOGY, MANAGEMENT, FINANCIAL, LEGAL, AUDIT, OTHER
  startDate     DateTime
  endDate       DateTime?
  budget        Decimal? @db.Decimal(15, 2)
  hourlyRate    Decimal? @db.Decimal(10, 2)
  totalHours    Decimal? @db.Decimal(10, 2)
  status        String   @default("ACTIVE")  // ACTIVE, ON_HOLD, COMPLETED, CANCELLED
  teamLead      String?
  deliverables  String[]
  notes         String?
  timeLogs      TimeLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
}

model TimeLog {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String
  project     ConsultingProject @relation(fields: [projectId], references: [id])
  userName    String
  date        DateTime
  hours       Decimal  @db.Decimal(5, 2)
  description String?
  billable    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([tenantId, projectId])
  @@index([tenantId, date])
}

// ══════════════════════════════════════════════
// MÓDULO: TELECOMUNICAÇÕES
// ══════════════════════════════════════════════

model TelecomSubscription {
  id            String   @id @default(cuid())
  tenantId      String
  clientName    String
  clientPhone   String?
  planName      String
  planType      String               // MOBILE, FIXED, INTERNET, TV, BUNDLE
  monthlyValue  Decimal  @db.Decimal(15, 2)
  startDate     DateTime
  endDate       DateTime?
  status        String   @default("ACTIVE")  // ACTIVE, SUSPENDED, CANCELLED, EXPIRED
  simNumber     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
}

// ══════════════════════════════════════════════
// MÓDULO: JURÍDICO & COMPLIANCE
// ══════════════════════════════════════════════

model LegalCase {
  id          String   @id @default(cuid())
  tenantId    String
  caseNumber  String?
  title       String
  caseType    String               // CIVIL, CRIMINAL, LABOR, TAX, COMMERCIAL, ADMINISTRATIVE, CONTRACT, OTHER
  clientName  String
  clientNif   String?
  court       String?
  judge       String?
  lawyer      String
  status      String   @default("OPEN")  // OPEN, IN_PROGRESS, HEARING, APPEALED, CLOSED, ARCHIVED
  priority    String   @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  filingDate  DateTime?
  nextHearing DateTime?
  outcome     String?
  fees        Decimal? @db.Decimal(15, 2)
  notes       String?
  documents   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, caseNumber])
}

// ══════════════════════════════════════════════
// MÓDULO: CONTABILIDADE
// ══════════════════════════════════════════════

model AccountingEntry {
  id          String   @id @default(cuid())
  tenantId    String
  entryNumber String?
  date        DateTime
  description String
  account     String               // código da conta (ex: "71.1.1")
  debit       Decimal  @db.Decimal(15, 2) @default(0)
  credit      Decimal  @db.Decimal(15, 2) @default(0)
  category    String?              // REVENUE, EXPENSE, ASSET, LIABILITY, EQUITY
  reference   String?              // FT, FR, RC, etc.
  referenceId String?
  reconciled  Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, account])
}
